# Stone Bounty - Git Ignore File

# Security sensitive files
.github_token
.wallet_address
*.env
.env.local
.env.development
.env.production

# Log files
*.log
logs/
*.log.*

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Backup files
*~
*.bak
*.backup

# Scripts output
output/
results/
data/

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# Cache directories
.cache/
.gitconfig.local

# Keep config templates but ignore actual configs
!config/templates/
config/*.json
!config/automation_config.json.template
!config/blacklisted_projects.json.template
!config/strategy_config.json.template